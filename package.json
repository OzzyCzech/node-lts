{
  "name": "node-versions-info",
  "version": "1.0.0",
  "description": "Get active Node.js LTS and current version numbers",
  "license": "MIT",
  "author": "Roman Ožana <roman@ozana.cz> (https://ozana.cz/)",
  "keywords": [
    "node",
    "nodejs",
    "lts",
    "version",
    "release"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OzzyCzech/node-versions-info.git"
  },
  "homepage": "https://github.com/OzzyCzech/node-versions-info#readme",
  "bugs": {
    "url": "https://github.com/OzzyCzech/node-versions-info/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "node-versions-info": "./dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup && chmod +x dist/cli.js",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
